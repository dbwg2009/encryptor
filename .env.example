# Required. Server-side secret used to generate deterministic salts for unknown
# emails (prevents account-enumeration). Rotate only if you accept that all
# unknown-email preflight responses change.
#   Generate with:  openssl rand -hex 32
CIPHER_SECRET=572171BCBB8BF1BA71BB5FCFC2EB3B69

# Optional. If set, /api/auth/register requires this exact token in the body.
# Use this to lock down public sign-ups after creating your first account.
# CIPHER_REGISTRATION_TOKEN=

# Optional. Name of the external Docker network used by Nginx Proxy Manager.
# If you don't put NPM and this app on the same network, leave this and use
# the 127.0.0.1:8765 host port + a "forward host" entry in NPM instead.
# NPM_NETWORK=npm_default
